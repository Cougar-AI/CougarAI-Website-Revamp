{
  "rewrites": [
    { "source": "/auth/:path*", "destination": "https://cai-dev-backend.cougarai.org/auth/:path*" },
    { "source": "/events/:path*", "destination": "https://cai-dev-backend.cougarai.org/events/:path*" },
    { "source": "/forms/:path*", "destination": "https://cai-dev-backend.cougarai.org/forms/:path*" },
    { "source": "/sponsors/:path*", "destination": "https://cai-dev-backend.cougarai.org/sponsors/:path*" },
    { "source": "/partners/:path*", "destination": "https://cai-dev-backend.cougarai.org/partners/:path*" },
    { "source": "/admin/:path*", "destination": "https://cai-dev-backend.cougarai.org/admin/:path*" },
    { "source": "/register/:path*", "destination": "https://cai-dev-backend.cougarai.org/register/:path*" },
    { "source": "/users/:path*", "destination": "https://cai-dev-backend.cougarai.org/users/:path*" },
    { "source": "/payments/:path*", "destination": "https://cai-dev-backend.cougarai.org/payments/:path*" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ]
}